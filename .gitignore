# =======================================================================
# Universal .gitignore Template
# =======================================================================

# --- Environment Variables & Secrets ---
# Never commit credentials, API keys, or private configuration files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
*.secret

# --- Operating System Files ---
# macOS specific files
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows specific files
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux specific files
*~
.fuse_hidden*
.directory
.trash/

# --- IDEs and Text Editors ---
# JetBrains (IntelliJ, WebStorm, PyCharm, etc.)
.idea/
*.iws

# Visual Studio Code
.vscode/
!.vscode/extensions.json
*.code-workspace
.history/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
.*.sw[a-z]
*.un~
Session.vim

# --- Common Crash Logs & Temporary Files ---
*.log
*.log.*
*.tmp
*.bak
*.swp

# --- Others ---
AGENTS.md

# --- Python Backend & Database ---
venv/
__pycache__/
*.db