# Copy this file to .env and replace the placeholders with values from:
# Supabase Dashboard > Project Settings > API.

# URL of the shared Supabase project (use the Singapore project URL).
SUPABASE_URL=https://your-project-ref.supabase.co

# Backend-only Supabase secret key (starts with sb_secret_).
# Never expose this key in browser JavaScript or commit a real key to Git.
SUPABASE_KEY=sb_secret_your_backend_key_here

# SQLite is used only by automated tests. Normal local and Vercel runs use
# the shared Supabase database for both module data and reviews.
